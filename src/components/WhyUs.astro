---
const features = [
  {
    icon: `<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>`,
    title: 'Wieloletnie doświadczenie',
    desc: 'Ponad 200 zrealizowanych projektów. Każdy wykonany z pełnym zaangażowaniem.',
  },
  {
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
    title: 'Terminowa realizacja',
    desc: 'Dotrzymujemy ustalonych terminów. Żadnych niespodzianek ani opóźnień.',
  },
  {
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    title: 'Indywidualne podejście',
    desc: 'Słuchamy klientów i dostosowujemy każdy projekt do ich potrzeb i budżetu.',
  },
  {
    icon: `<path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/>`,
    title: 'Wysoka jakość',
    desc: 'Sprawdzone materiały, sprawdzone techniki — efekt, który przetrwa lata.',
  },
  {
    icon: `<path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>`,
    title: 'Konkurencyjne ceny',
    desc: 'Uczciwa, przejrzysta wycena bez ukrytych kosztów i niespodzianek.',
  },
  {
    icon: `<polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>`,
    title: 'Darmowa wycena',
    desc: 'Bezpłatna wizyta u klienta i szczegółowy kosztorys w ciągu 24 godzin.',
  },
];
---

<section class="whyus" id="dlaczego-my" aria-labelledby="whyus-heading">
  <div class="container whyus__grid">
    <!-- Left content -->
    <div class="whyus__left">
      <p class="section-label whyus__label" data-animate="fade-up">Dlaczego My</p>
      <h2 id="whyus-heading" class="section-heading section-heading--white" data-animate="fade-up" data-animate-delay="100">
        Co nas wyróżnia<br/>
        <span>na tle konkurencji</span>
      </h2>
      <p class="whyus__desc" data-animate="fade-up" data-animate-delay="200">
        Wybierając DamBud wybierasz spokój ducha — profesjonalną
        ekipę, która dotrzymuje słowa i dostarcza rezultaty.
      </p>
      <div data-animate="fade-up" data-animate-delay="300">
        <a href="#kontakt" class="btn btn-primary">
          Skontaktuj się z nami
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <!-- Right features grid -->
    <div class="whyus__features" role="list">
      {features.map((feat, i) => (
        <article
          class="whyus__card"
          role="listitem"
          data-animate="fade-up"
          data-animate-delay={String(i * 80)}
        >
          <div class="icon-box whyus__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={feat.icon} />
            </svg>
          </div>
          <div>
            <h3 class="whyus__card-title">{feat.title}</h3>
            <p class="whyus__card-desc">{feat.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .whyus {
    padding: clamp(var(--space-16), 8vw, var(--space-32)) 0;
    background: var(--clr-dark);
    overflow: hidden;
  }

  .whyus__grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(var(--space-12), 8vw, var(--space-24));
    align-items: center;
  }

  /* Left */
  .whyus__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .whyus__label {
    color: var(--clr-orange);
  }

  .whyus__label::before {
    background: var(--clr-orange);
  }

  .whyus__desc {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
  }

  /* Features */
  .whyus__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  .whyus__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-7) var(--space-6);
    background: rgba(255,255,255,0.04);
    border-radius: var(--radius-md);
    transition: background var(--transition), transform var(--transition);
  }

  .whyus__card:hover {
    background: rgba(255,255,255,0.08);
    transform: translateY(-2px);
  }

  .whyus__icon {
    background: rgba(229, 90, 0, 0.12);
    border: none;
    transition: background var(--transition);
  }

  .whyus__card:hover .whyus__icon {
    background: var(--clr-orange);
  }

  .whyus__card:hover .whyus__icon svg {
    stroke: var(--clr-white);
    color: var(--clr-white);
  }

  .whyus__card-title {
    font-size: var(--fs-base);
    font-weight: var(--fw-bold);
    color: var(--clr-white);
    line-height: 1.3;
  }

  .whyus__card-desc {
    font-size: var(--fs-sm);
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .whyus__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .whyus__features {
      grid-template-columns: 1fr;
    }
  }
</style>
