---
const testimonials = [
  {
    initials: 'PS',
    name: 'Piotr S.',
    when: 'miesiąc temu',
    rating: 5,
    text: 'Z pełnym przekonaniem polecam Damiana i całą ekipę remontową. Jestem bardzo zadowolony z wykonania generalnego remontu — wszystkie prace wykonane solidnie i terminowo.',
  },
  {
    initials: 'MB',
    name: 'Miłosz Bąbliński',
    when: '2 miesiące temu',
    rating: 5,
    text: 'Szczerze polecam usługi DamBud. Generalny remont łazienki przeprowadzony szybko, porządnie i zgodnie z początkowymi założeniami (2 tyg). Jestem bardzo zadowolony z efektu.',
  },
  {
    initials: 'PŚ',
    name: 'Patryk Śmigielski',
    when: '5 miesięcy temu',
    rating: 5,
    text: 'Wylewka samopoziomująca wykonana perfekcyjnie. Pełen profesjonalizm, szybko i bardzo sprawnie. Cena bardzo dobra i w 100% adekwatna do jakości wykonania. Mega chłopaki – przesympatyczni ludzie, świetny kontakt i solidna robota. Z czystym sumieniem polecam!',
  },
  {
    initials: 'AK',
    name: 'Anna Krzeszowska',
    when: '4 tygodnie temu',
    rating: 5,
    text: 'Jestem bardzo zadowolona — konkretny, terminowy fachowiec. Praca bez zarzutu, remont łazienki przebiegł szybko. Pozdrawiam!',
  },
  {
    initials: 'AP',
    name: 'Andrzej Pańczyk',
    when: 'miesiąc temu',
    rating: 5,
    text: 'Szybko, czysto, perfekcyjnie — polecam. Gdyby wszyscy budowlańcy byli takimi fachowcami jak Pan Damian, budowa czy też remont domu byłyby bezproblemowe.',
  },
  {
    initials: 'AS',
    name: 'Aleksandra Sobolewska',
    when: 'miesiąc temu',
    rating: 5,
    text: 'Polecamy! Panowie sprawnie i profesjonalnie zamontowali litery nad wejściem do naszej kliniki. Wszystko poszło szybko, komunikacja bez problemu, a efekt końcowy wygląda świetnie.',
  },
  {
    initials: 'KC',
    name: 'Krzysztof C.',
    when: '7 miesięcy temu',
    rating: 5,
    text: 'W 100% polecam wykonawcę. Wyjątkowo sprawnie i rzetelnie wykonana usługa. Bardzo dobry kontakt i elastyczność — gdy z przyczyn obiektywnych przesunęliśmy termin, wszystko zostało sprawnie dostosowane.',
  },
  {
    initials: 'JW',
    name: 'Joanna Wnuk',
    when: 'rok temu',
    rating: 5,
    text: 'Świetna robota! Jestem niezwykle zadowolona. Bardzo profesjonalna firma. Punktualni i dokładni. Kafelki w mojej kuchni wyglądają fantastycznie. Szczerze polecam tę firmę każdemu, kto szuka fachowców do układania kafelek!',
  },
  {
    initials: 'NK',
    name: 'Natalia Konopacka',
    when: 'rok temu',
    rating: 5,
    text: 'Polecam! Świetny fachowiec, porządny i sumienny, super kontakt — regularnie wysyłał zdjęcia z remontu i informacje o postępach. Generalny remont całego mieszkania wykonany wzorowo.',
  },
  {
    initials: 'MZ',
    name: 'Monika Zysk-Gawan',
    when: '11 miesięcy temu',
    rating: 5,
    text: 'Firma Pana Damiana to profesjonalizm, rzetelność i świetny kontakt z klientem. U nas zostało wykonane docieplenie skosów w pokojach i malowanie. Wszystko perfekcyjnie.',
  },
  {
    initials: 'SM',
    name: 'Szymon Mytych',
    when: '3 tygodnie temu',
    rating: 5,
    text: 'Robota wykonana terminowo i sprawnie, ekipa kontaktowa i do dogadania w każdej sprawie. Polecam!',
  },
  {
    initials: 'TK',
    name: 'Tomasz Kędzior',
    when: 'rok temu',
    rating: 5,
    text: 'Super ekipa. Prace zaplanowane na 1,5 tyg skończone po 4 dniach z ogromną dokładnością i przede wszystkim czysto. Posprzątanie po remoncie wiązało się tylko z kosmetyką. Bardzo polecam.',
  },
  {
    initials: 'TS',
    name: 'Tomasz Sobotka',
    when: '9 miesięcy temu',
    rating: 5,
    text: 'Bardzo polecam, jestem bardzo zadowolony. Solidna ekipa, prace wykonane bezbłędnie idealnie. Dużo fajnych pomysłów, porządek na budowie, efekt końcowy na 120%. Polecam!',
  },
  {
    initials: 'MG',
    name: 'Monika Graczyk',
    when: '2 lata temu',
    rating: 5,
    text: 'Polecam wykonawcę! Na co dzień mam doświadczenie z ekipami remontowymi. DamBud to solidny, perfekcyjny, dbający o szczegóły i terminowy Pan Damian. Dziękuję za ukończenie skomplikowanego projektu na czas i zgodnie z założeniami.',
  },
  {
    initials: 'JG',
    name: 'Jan Gruna',
    when: 'rok temu',
    rating: 5,
    text: 'Jestem pod wrażeniem jakie doświadczenie ma ten Pan w tak młodym wieku. Usługi które wykonuje muszę przyznać, że są na najwyższym poziomie. Nie spotkałem się dotąd z takim podejściem do klienta.',
  },
  {
    initials: 'AK',
    name: 'Anna Kreft',
    when: '9 miesięcy temu',
    rating: 5,
    text: 'Praca wykonana szybko, bez zarzutu. Czysto, zadbane miejsce pracy, porządek po zakończeniu prac. Polecam!',
  },
  {
    initials: 'KJ',
    name: 'Krystian Janas',
    when: '5 miesięcy temu',
    rating: 5,
    text: 'W 100% polecam firmę. Bardzo dobry kontakt, wylewka wykonana bardzo dobrze.',
  },
];
---

<section class="testimonials" id="opinie" aria-labelledby="testimonials-heading">
  <div class="container testimonials__inner">
    <!-- Left: main testimonial -->
    <div class="testimonials__main">
      <p class="section-label" data-animate="fade-up">Opinie Klientów</p>
      <h2 id="testimonials-heading" class="section-heading" data-animate="fade-up" data-animate-delay="100">
        Co mówią<br/>
        <span>Nasi Klienci</span>
      </h2>

      <!-- Google badge -->
      <div class="testimonials__google" data-animate="fade-up" data-animate-delay="150">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Opinie z Google · 5.0 ★ · 17 opinii
      </div>

      <!-- Quote -->
      <div class="testimonials__quote-wrap" data-animate="fade-up" data-animate-delay="200">
        <div class="testimonials__quote-icon" aria-hidden="true">,,</div>
        <blockquote class="testimonials__quote" id="main-quote">
          {testimonials[0].text}
        </blockquote>
        <div class="testimonials__author">
          <div class="testimonials__avatar" id="main-avatar">
            {testimonials[0].initials}
          </div>
          <div>
            <p class="testimonials__name" id="main-name">{testimonials[0].name}</p>
            <p class="testimonials__location" id="main-when">{testimonials[0].when} · Google</p>
          </div>
          <div class="testimonials__stars" id="main-stars" aria-label="Ocena 5 na 5 gwiazdek">
            {'★'.repeat(5)}
          </div>
        </div>
      </div>
    </div>

    <!-- Right: counter + sidebar -->
    <div class="testimonials__right" data-animate="fade-right" data-animate-delay="200">
      <!-- Counter + nav -->
      <div class="testimonials__nav">
        <div class="testimonials__counter">
          <span class="testimonials__counter-current" id="counter-current">01</span>
          <span class="testimonials__counter-sep"> / </span>
          <span class="testimonials__counter-total">{String(testimonials.length).padStart(2, '0')}</span>
        </div>
        <div class="testimonials__dots" id="testimonials-dots" aria-label="Wskaźniki slajdów">
          {testimonials.map((_, i) => (
            <button
              class={`testimonials__dot${i === 0 ? ' active' : ''}`}
              data-index={i}
              aria-label={`Przejdź do opinii ${i + 1}`}
            ></button>
          ))}
        </div>
        <div class="testimonials__arrows">
          <button class="testimonials__arrow" id="prev-btn" aria-label="Poprzednia opinia">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="testimonials__arrow testimonials__arrow--active" id="next-btn" aria-label="Następna opinia">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>

      <!-- Sidebar list -->
      <div class="testimonials__sidebar" id="testimonials-sidebar">
        {testimonials.slice(1, 3).map((t, i) => (
          <button
            class="testimonials__card"
            data-index={i + 1}
            aria-label={`Pokaż opinię od ${t.name}`}
          >
            <div class="testimonials__card-header">
              <div class="testimonials__card-avatar">{t.initials}</div>
              <div>
                <span class="testimonials__card-name">{t.name}</span>
                <span class="testimonials__card-when">{t.when}</span>
              </div>
              <span class="testimonials__card-stars">★★★★★</span>
            </div>
            <p class="testimonials__card-text">{t.text.slice(0, 110)}…</p>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: clamp(var(--space-16), 8vw, var(--space-32)) 0;
    background: var(--clr-beige);
  }

  .testimonials__inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(var(--space-10), 6vw, var(--space-20));
    align-items: start;
  }

  /* Main */
  .testimonials__main {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Google badge */
  .testimonials__google {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semi);
    color: var(--clr-text-muted);
    background: var(--clr-white);
    border: 1px solid var(--clr-border);
    border-radius: 50px;
    padding: var(--space-2) var(--space-4);
    width: fit-content;
  }

  .testimonials__quote-wrap {
    position: relative;
  }

  .testimonials__quote-icon {
    font-size: 7rem;
    line-height: 0.6;
    color: var(--clr-orange);
    opacity: 0.15;
    font-family: Georgia, serif;
    user-select: none;
    margin-bottom: var(--space-4);
  }

  .testimonials__quote {
    font-size: clamp(var(--fs-md), 2vw, var(--fs-lg));
    font-weight: var(--fw-medium);
    color: var(--clr-text);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    font-style: normal;
    transition: opacity 0.35s ease;
  }

  .testimonials__quote.fading {
    opacity: 0;
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .testimonials__avatar {
    width: 52px;
    height: 52px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--fs-sm);
    font-weight: var(--fw-black);
    color: var(--clr-white);
    background: var(--clr-orange);
    flex-shrink: 0;
    letter-spacing: 0.03em;
  }

  .testimonials__name {
    font-size: var(--fs-base);
    font-weight: var(--fw-bold);
    color: var(--clr-text);
  }

  .testimonials__location {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    margin-top: 2px;
  }

  .testimonials__stars {
    margin-left: auto;
    color: var(--clr-orange);
    font-size: var(--fs-md);
    letter-spacing: 2px;
  }

  /* Right */
  .testimonials__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-top: var(--space-12);
  }

  .testimonials__nav {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .testimonials__counter {
    font-size: var(--fs-xl);
    font-weight: var(--fw-black);
    color: var(--clr-text);
  }

  .testimonials__counter-current {
    color: var(--clr-orange);
  }

  .testimonials__counter-sep,
  .testimonials__counter-total {
    color: var(--clr-text-light);
    font-size: var(--fs-base);
  }

  .testimonials__dots {
    display: flex;
    gap: var(--space-2);
    margin-left: var(--space-2);
    flex-wrap: wrap;
    max-width: 180px;
  }

  .testimonials__dot {
    width: 16px;
    height: 3px;
    border-radius: 2px;
    background: var(--clr-border);
    cursor: pointer;
    transition: background var(--transition), width var(--transition);
  }

  .testimonials__dot.active {
    background: var(--clr-orange);
    width: 28px;
  }

  .testimonials__arrows {
    display: flex;
    gap: var(--space-2);
    margin-left: auto;
  }

  .testimonials__arrow {
    width: 40px;
    height: 40px;
    border: 1.5px solid var(--clr-border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-text-muted);
    transition: all var(--transition);
    cursor: pointer;
  }

  .testimonials__arrow:hover,
  .testimonials__arrow--active {
    background: var(--clr-orange);
    border-color: var(--clr-orange);
    color: var(--clr-white);
  }

  /* Sidebar */
  .testimonials__sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .testimonials__card {
    background: var(--clr-white);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    cursor: pointer;
    text-align: left;
    border: 1.5px solid transparent;
    transition: border-color var(--transition), box-shadow var(--transition);
    box-shadow: var(--shadow-sm);
  }

  .testimonials__card:hover {
    border-color: var(--clr-orange);
    box-shadow: var(--shadow-md);
  }

  .testimonials__card-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .testimonials__card-avatar {
    width: 34px;
    height: 34px;
    border-radius: 3px;
    background: rgba(229,90,0,0.12);
    color: var(--clr-orange);
    font-size: var(--fs-xs);
    font-weight: var(--fw-black);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonials__card-name {
    display: block;
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    color: var(--clr-text);
  }

  .testimonials__card-when {
    display: block;
    font-size: var(--fs-xs);
    color: var(--clr-text-muted);
    margin-top: 1px;
  }

  .testimonials__card-stars {
    margin-left: auto;
    color: var(--clr-orange);
    font-size: var(--fs-xs);
    letter-spacing: 1px;
    flex-shrink: 0;
  }

  .testimonials__card-text {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .testimonials__inner {
      grid-template-columns: 1fr;
    }

    .testimonials__right {
      padding-top: 0;
    }
  }
</style>

