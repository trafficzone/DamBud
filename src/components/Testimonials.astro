    { initials: 'AK', name: 'Anna Kreft', when: '9 miesięcy temu', text: 'Praca wykonana szybko, bez zarzutu. Czysto, zadbane miejsce pracy, porządek po zakończeniu prac. Polecam!' },
    { initials: 'KJ', name: 'Krystian Janas', when: '5 miesięcy temu', text: 'W 100% polecam firmę. Bardzo dobry kontakt, wylewka wykonana bardzo dobrze.' },
  ];

  let current = 0;

  const quoteEl    = document.getElementById('main-quote')!;
  const nameEl     = document.getElementById('main-name')!;
  const whenEl     = document.getElementById('main-when')!;
  const counterEl  = document.getElementById('counter-current')!;
  const dots       = document.querySelectorAll<HTMLElement>('.testimonials__dot');
  const cards      = document.querySelectorAll<HTMLElement>('.testimonials__card');

  const goTo = (index: number) => {
    current = (index + testimonials.length) % testimonials.length;
    const t = testimonials[current];

    quoteEl.classList.add('fading');

    setTimeout(() => {
      quoteEl.textContent      = t.text;
      nameEl.textContent       = t.name;
      whenEl.textContent       = `${t.when} · Google`;
      counterEl.textContent    = String(current + 1).padStart(2, '0');

      dots.forEach((d, i) => d.classList.toggle('active', i === current));

      const sidebarIndices = [(current + 1) % testimonials.length, (current + 2) % testimonials.length];
      cards.forEach((card, ci) => {
        const t2 = testimonials[sidebarIndices[ci]];
        if (!t2) return;
        const nameEl2   = card.querySelector('.testimonials__card-name');
        const whenEl2   = card.querySelector('.testimonials__card-when');
        const txtEl     = card.querySelector('.testimonials__card-text');
        const avatarEl  = card.querySelector('.testimonials__card-avatar');
        if (nameEl2)  nameEl2.textContent  = t2.name;
        if (whenEl2)  whenEl2.textContent  = t2.when;
        if (txtEl)    txtEl.textContent    = t2.text.slice(0, 110) + '…';
        if (avatarEl) avatarEl.textContent = t2.initials;
        (card as HTMLElement).dataset.index = String(sidebarIndices[ci]);
      });

      quoteEl.classList.remove('fading');
    }, 300);
  };

  document.getElementById('next-btn')?.addEventListener('click', () => goTo(current + 1));
  document.getElementById('prev-btn')?.addEventListener('click', () => goTo(current - 1));

  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const idx = parseInt((card as HTMLElement).dataset.index || '0', 10);
      goTo(idx);
    });
  });

  let autoTimer = setInterval(() => goTo(current + 1), 6000);
  const section = document.querySelector('.testimonials')!;
  section.addEventListener('mouseenter', () => clearInterval(autoTimer));
  section.addEventListener('mouseleave', () => {
    autoTimer = setInterval(() => goTo(current + 1), 6000);
  });
</script>
