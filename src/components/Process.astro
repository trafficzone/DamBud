---
const steps = [
  {
    number: '01',
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
    title: 'Kontakt i konsultacja',
    desc: 'Skontaktuj się telefonicznie lub przez formularz. Umówimy bezpłatną wizytę, by omówić zakres i specyfikę prac.',
    highlight: false,
  },
  {
    number: '02',
    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>`,
    title: 'Darmowa wycena',
    desc: 'Przygotujemy szczegółowy kosztorys z pełną specyfikacją materiałów i robocizny. Żadnych ukrytych opłat.',
    highlight: true,
  },
  {
    number: '03',
    icon: `<path d="M2 20h.01M7 20v-4"/><path d="M12 20v-8"/><path d="M17 20V8"/><path d="M22 4v16"/>`,
    title: 'Realizacja prac',
    desc: 'Doświadczony zespół pracuje zgodnie z harmonogramem. Dbamy o porządek, bezpieczeństwo i regularny kontakt.',
    highlight: false,
  },
  {
    number: '04',
    icon: `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`,
    title: 'Odbiór projektu',
    desc: 'Wspólnie odbieramy gotowe wnętrze. Twoja pełna satysfakcja to nasz cel nadrzędny.',
    highlight: false,
  },
];
---

<section class="process" id="jak-dzialamy" aria-labelledby="process-heading">
  <div class="container">
    <!-- Header -->
    <div class="process__header" data-animate="fade-up">
      <p class="section-label process__label">Jak Działamy</p>
      <h2 id="process-heading" class="section-heading process__heading">
        Proces <span>Współpracy</span>
      </h2>
    </div>

    <!-- Steps -->
    <div class="process__steps" role="list">
      {steps.map((step, i) => (
        <article
          class={`process__step${step.highlight ? ' process__step--highlight' : ''}`}
          role="listitem"
          data-animate="fade-up"
          data-animate-delay={String(i * 100)}
        >
          <!-- Big number -->
          <span class="process__number" aria-hidden="true">{step.number}</span>

          <!-- Icon box -->
          <div class="icon-box process__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={step.icon} />
            </svg>
          </div>

          <h3 class={`process__step-title${step.highlight ? ' process__step-title--highlight' : ''}`}>
            {step.title}
          </h3>
          <p class="process__step-desc">{step.desc}</p>
        </article>
      ))}
    </div>

    <!-- Connector line (desktop) -->
    <div class="process__line" aria-hidden="true"></div>

    <!-- CTA -->
    <div class="process__cta" data-animate="fade-up">
      <a href="#kontakt" class="btn btn-primary">
        Rozpocznij projekt
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="tel:+48794722003" class="process__phone">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.79a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.4 16l.02.92z"/>
        </svg>
        +48 794 722 003
      </a>
    </div>
  </div>
</section>

<style>
  .process {
    padding: clamp(var(--space-16), 8vw, var(--space-32)) 0;
    background: var(--clr-white);
    overflow: hidden;
  }

  /* Header */
  .process__header {
    text-align: center;
    margin-bottom: clamp(var(--space-12), 6vw, var(--space-20));
  }

  .process__label {
    justify-content: center;
  }

  .process__label::before,
  .process__label::after {
    content: '';
    display: block;
    height: 2px;
    width: 32px;
    background: var(--clr-orange);
  }

  .process__heading {
    text-align: center;
  }

  /* Steps */
  .process__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    position: relative;
  }

  /* Connector line */
  .process__line {
    position: absolute;
    top: 50%;
    left: var(--container-padding);
    right: var(--container-padding);
    height: 1px;
    background: var(--clr-border);
    pointer-events: none;
    display: none;
  }

  /* Step */
  .process__step {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--clr-border);
    position: relative;
  }

  .process__step--highlight .process__icon {
    background: var(--clr-orange);
    border-color: var(--clr-orange);
  }

  .process__step--highlight .process__icon svg {
    stroke: var(--clr-white);
    color: var(--clr-white);
  }

  .process__number {
    font-size: clamp(var(--fs-4xl), 6vw, 5rem);
    font-weight: var(--fw-black);
    color: rgba(0,0,0,0.06);
    line-height: 1;
    letter-spacing: -0.03em;
    user-select: none;
  }

  .process__icon {
    width: 48px;
    height: 48px;
  }

  .process__step-title {
    font-size: var(--fs-base);
    font-weight: var(--fw-bold);
    color: var(--clr-text);
    line-height: 1.3;
  }

  .process__step-title--highlight {
    color: var(--clr-orange);
  }

  .process__step-desc {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    line-height: 1.65;
  }

  /* CTA */
  .process__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    margin-top: clamp(var(--space-10), 5vw, var(--space-16));
    flex-wrap: wrap;
  }

  .process__phone {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    color: var(--clr-orange);
    transition: color var(--transition);
  }

  .process__phone:hover {
    color: var(--clr-orange-dark);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .process__steps {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  @media (max-width: 600px) {
    .process__steps {
      grid-template-columns: 1fr;
    }
  }
</style>
