<div class="floating-cta" id="floating-cta" aria-label="Szybki kontakt">
  <a href="#kontakt" class="floating-cta__btn" aria-label="Darmowa wycena - przejdź do formularza">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.79a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.4 16l.02.92z"/>
    </svg>
    <span class="floating-cta__label">Darmowa wycena</span>
  </a>
</div>

<style>
  .floating-cta {
    position: fixed;
    bottom: var(--space-8);
    right: var(--space-6);
    z-index: 900;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }

  .floating-cta.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .floating-cta__btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--clr-orange);
    color: var(--clr-white);
    padding: 0.85rem 1.4rem;
    border-radius: 50px;
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    box-shadow: 0 4px 24px rgba(229,90,0,0.45);
    white-space: nowrap;
    transition: all var(--transition);
  }

  .floating-cta__btn:hover {
    background: var(--clr-orange-dark);
    box-shadow: 0 6px 30px rgba(229,90,0,0.55);
    transform: translateY(-2px);
  }

  /* Pulse ring animation */
  .floating-cta__btn::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50px;
    border: 2px solid var(--clr-orange);
    opacity: 0;
    animation: pulse-ring 2.5s ease-out infinite;
  }

  .floating-cta {
    position: fixed;
  }

  @keyframes pulse-ring {
    0%   { transform: scale(1);   opacity: 0.6; }
    70%  { transform: scale(1.12); opacity: 0;  }
    100% { transform: scale(1.12); opacity: 0;  }
  }

  @media (max-width: 480px) {
    .floating-cta__label {
      display: none;
    }

    .floating-cta__btn {
      width: 52px;
      height: 52px;
      padding: 0;
      justify-content: center;
      border-radius: 50%;
    }

    .floating-cta__btn::before {
      border-radius: 50%;
    }
  }
</style>

<script>
  const floatingCta = document.getElementById('floating-cta')!;

  window.addEventListener('scroll', () => {
    floatingCta.classList.toggle('visible', window.scrollY > 400);
  }, { passive: true });
</script>
