---
---

<section class="cta-banner" aria-label="Wezwanie do działania">
  <div class="container cta-banner__inner">
    <div class="cta-banner__text" data-animate="fade-left">
      <h2 class="cta-banner__heading">Gotowy na remont? Zadzwoń lub napisz już dziś.</h2>
      <p class="cta-banner__sub">Bezpłatna wycena i konsultacja — odpowiedź w 24 godziny.</p>
    </div>
    <div class="cta-banner__actions" data-animate="fade-right" data-animate-delay="150">
      <a href="tel:+48794722003" class="cta-banner__phone-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.79a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.4 16l.02.92z"/>
        </svg>
        +48 794 722 003
      </a>
      <a href="#kontakt" class="btn btn-outline">
        Formularz kontaktowy
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    background: var(--clr-orange);
    padding: clamp(var(--space-8), 4vw, var(--space-12)) 0;
  }

  .cta-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .cta-banner__heading {
    font-size: clamp(var(--fs-lg), 2.5vw, var(--fs-2xl));
    font-weight: var(--fw-black);
    color: var(--clr-white);
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .cta-banner__sub {
    font-size: var(--fs-sm);
    color: rgba(255,255,255,0.8);
    margin-top: var(--space-2);
  }

  .cta-banner__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .cta-banner__phone-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.875rem 1.5rem;
    background: var(--clr-white);
    color: var(--clr-orange);
    font-size: var(--fs-base);
    font-weight: var(--fw-bold);
    border-radius: var(--radius-sm);
    transition: all var(--transition);
    white-space: nowrap;
  }

  .cta-banner__phone-btn:hover {
    background: rgba(255,255,255,0.9);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .cta-banner__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .cta-banner__actions {
      white-space: normal;
      flex-wrap: wrap;
      width: 100%;
    }

    .cta-banner__phone-btn {
      flex: 1;
      justify-content: center;
    }
  }
</style>
