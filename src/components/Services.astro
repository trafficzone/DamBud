---
const services = [
  {
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
    name: 'Kompleksowe wykończenia',
    desc: 'Mieszkań i domów od surowego stanu do efektu końcowego z pełnym nadzorem.',
  },
  {
    icon: `<path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/>`,
    name: 'Malowanie ścian i sufitów',
    desc: 'Perfekcyjne pokrycie farbami dekoracyjnymi, strukturalnymi i matowymi.',
  },
  {
    icon: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
    name: 'Gładzie gipsowe',
    desc: 'Precyzyjne wyrównanie powierzchni zapewniające idealną bazę pod malowanie.',
  },
  {
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
    name: 'Panele i podłogi',
    desc: 'Układanie paneli laminowanych, winylowych i podłóg z drewna litego.',
  },
  {
    icon: `<rect x="2" y="3" width="8" height="18" rx="1"/><path d="M10 7h4a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-4"/><path d="M22 7l-3-3v14l3-3"/>`,
    name: 'Montaż drzwi',
    desc: 'Drzwi wewnętrzne i zewnętrzne z regulacją ościeżnicy i futryny.',
  },
  {
    icon: `<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>`,
    name: 'Płytki i glazura',
    desc: 'Precyzyjne układanie w dowolne wzory — duże formaty, mozaiki, jodełka.',
  },
  {
    icon: `<path d="M2 20h20"/><path d="M6 20V10"/><path d="M18 20V10"/><path d="M10 20v-6"/><path d="M14 20v-6"/><path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/>`,
    name: 'Zabudowy karton-gips',
    desc: 'Ścianki działowe, nisze, obudowy grzejników i szafy na wymiar.',
  },
  {
    icon: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 12 12 17 22 12"/>`,
    name: 'Sufity podwieszane',
    desc: 'Systemowe i gipsowe z dowolną architekturą oświetlenia LED.',
  },
  {
    icon: `<path d="M4 22V12a8 8 0 0 1 16 0v10"/><path d="M2 22h20"/><path d="M7 22v-5a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v5"/>`,
    name: 'Remonty łazienek',
    desc: 'Kompleksowa przebudowa — od instalacji hydraulicznej po wyposażenie.',
  },
  {
    icon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
    name: 'Adaptacje wnętrz',
    desc: 'Wyburzenia, zmiany układu, tworzenie nowych, funkcjonalnych przestrzeni.',
  },
];
---

<section class="services" id="uslugi" aria-labelledby="services-heading">
  <div class="container">
    <!-- Header -->
    <div class="services__header">
      <div class="services__header-left">
        <p class="section-label" data-animate="fade-up">Nasze Usługi</p>
        <h2 id="services-heading" class="section-heading" data-animate="fade-up" data-animate-delay="100">
          Pełny zakres<br/>
          <span>Wykończeń Wnętrz</span>
        </h2>
      </div>
      <p class="services__header-text" data-animate="fade-up" data-animate-delay="200">
        Kompleksowa obsługa — od pierwszej<br/>
        konsultacji aż po odbiór gotowego wnętrza.
      </p>
    </div>

    <!-- Grid -->
    <div class="services__grid" role="list">
      {services.map((service, i) => (
        <a
          href="/oferta"
          class="services__card"
          data-num={String(i + 1).padStart(2, '0')}
          role="listitem"
          data-animate="fade-up"
          data-animate-delay={String(Math.min(i * 60, 500))}
        >
          <!-- Row 1: ordinal number + arrow -->
          <div class="services__row-top">
            <span class="services__ordinal" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="services__arrow" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </span>
          </div>

          <!-- Icon -->
          <div class="services__icon-wrap" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={service.icon} />
            </svg>
          </div>

          <!-- Text -->
          <h3 class="services__name">{service.name}</h3>
          <p class="services__desc">{service.desc}</p>

          <!-- Bottom accent line -->
          <span class="services__accent" aria-hidden="true"></span>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="services__cta" data-animate="fade-up">
      <a href="/oferta" class="btn btn-outline-dark">
        Zobacz wszystkie usługi
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
      <a href="#kontakt" class="btn btn-primary">
        Zapytaj o wycenę
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .services {
    padding: clamp(var(--space-16), 8vw, var(--space-32)) 0;
    background: var(--clr-beige);
  }

  /* Header */
  .services__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
    margin-bottom: clamp(var(--space-10), 5vw, var(--space-16));
    flex-wrap: wrap;
  }

  .services__header-left {
    flex: 1;
    min-width: 260px;
  }

  .services__header-text {
    font-size: var(--fs-md);
    color: var(--clr-text-muted);
    line-height: 1.6;
    text-align: right;
    padding-bottom: var(--space-2);
  }

  /* Grid */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-4);
  }

  /* Card */
  .services__card {
    position: relative;
    padding: var(--space-7) var(--space-6) var(--space-8);
    background: var(--clr-white);
    border-radius: var(--radius-md);
    border: 1px solid rgba(0, 0, 0, 0.07);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  /* Large watermark number via pseudo-element */
  .services__card::before {
    content: attr(data-num);
    position: absolute;
    bottom: -0.15em;
    right: 0.2em;
    font-size: 5.5rem;
    font-weight: 900;
    line-height: 1;
    color: var(--clr-text);
    opacity: 0.045;
    pointer-events: none;
    letter-spacing: -0.04em;
    font-family: var(--ff-heading);
    transition: opacity 0.3s ease, color 0.3s ease;
    user-select: none;
  }

  .services__card:hover {
    transform: translateY(-5px);
    box-shadow: 0 14px 44px rgba(0, 0, 0, 0.11);
    border-color: rgba(229, 90, 0, 0.3);
  }

  .services__card:hover::before {
    opacity: 0.09;
    color: var(--clr-orange);
  }

  /* Top row: ordinal + arrow */
  .services__row-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 24px;
  }

  .services__ordinal {
    font-size: 0.7rem;
    font-weight: var(--fw-bold);
    letter-spacing: 0.1em;
    color: var(--clr-orange);
    opacity: 0.7;
    line-height: 1;
  }

  .services__card:hover .services__ordinal {
    opacity: 1;
  }

  /* Arrow — hidden, slides in on hover */
  .services__arrow {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: transparent;
    border: 1.5px solid rgba(229, 90, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-orange);
    opacity: 0;
    transform: translateX(-8px) scale(0.85);
    transition: opacity 0.25s ease, transform 0.25s ease, background 0.25s ease;
    flex-shrink: 0;
  }

  .services__card:hover .services__arrow {
    opacity: 1;
    transform: translateX(0) scale(1);
    background: var(--clr-orange);
    border-color: var(--clr-orange);
    color: var(--clr-white);
  }

  /* Icon */
  .services__icon-wrap {
    width: 48px;
    height: 48px;
    background: rgba(229, 90, 0, 0.08);
    border: 1px solid rgba(229, 90, 0, 0.15);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-orange);
    flex-shrink: 0;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }

  .services__card:hover .services__icon-wrap {
    background: var(--clr-orange);
    border-color: var(--clr-orange);
    color: var(--clr-white);
    transform: scale(1.07);
  }

  /* Text */
  .services__name {
    font-size: var(--fs-base);
    font-weight: var(--fw-bold);
    color: var(--clr-text);
    line-height: 1.3;
    transition: color 0.3s ease;
    margin-top: var(--space-1);
  }

  .services__card:hover .services__name {
    color: var(--clr-orange);
  }

  .services__desc {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    line-height: 1.65;
    flex: 1;
  }

  /* Bottom accent */
  .services__accent {
    display: block;
    height: 3px;
    border-radius: 2px;
    background: var(--clr-orange);
    width: 0;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    margin-top: var(--space-2);
  }

  .services__card:hover .services__accent {
    width: 40%;
  }

  /* CTA */
  .services__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-top: clamp(var(--space-8), 4vw, var(--space-12));
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .services__header-text {
      text-align: left;
    }

    .services__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-3);
    }
  }

  @media (max-width: 480px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
